IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[spCOM_SetCostCenter]') AND type in (N'P', N'PC'))
DROP PROCEDURE [dbo].[spCOM_SetCostCenter]
GO
